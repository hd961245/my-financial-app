# ─── 資料庫 ──────────────────────────────────────────────────────────
# PostgreSQL 連線字串（Vercel Postgres、Neon、Supabase 等皆可）
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# ─── AI 模型 API Keys ─────────────────────────────────────────────────
# OpenAI — 用於個股 AI 分析、每日推薦、AI 聊天（擇一或兩者皆設）
OPENAI_API_KEY="sk-..."

# Google Gemini — 用於 AI 聊天雙模型對比
GEMINI_API_KEY="AIza..."

# ─── Google Sheets 整合 ───────────────────────────────────────────────
# Service Account 憑證（JSON 轉 Base64）
# 產生方式：base64 -i service-account.json | tr -d '\n'
GOOGLE_SERVICE_ACCOUNT_BASE64=""

# ─── Discord 整合（選填）─────────────────────────────────────────────
# Discord Bot Token — 用於社群助理功能
DISCORD_BOT_TOKEN=""

# Discord Webhook URL — 用於推送通知
DISCORD_WEBHOOK_URL=""

# ─── Cron Job 安全性 ──────────────────────────────────────────────────
# 保護 /api/cron/* 路由，Vercel Cron 呼叫時需帶此 Header
# 建議設一組隨機字串：openssl rand -hex 32
CRON_SECRET=""
