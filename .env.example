# ════════════════════════════════════════════════════════════════════════════
#  環境變數設定說明
#  複製此檔為 .env.local（本地開發）或填入 Vercel → Settings → Environment Variables
# ════════════════════════════════════════════════════════════════════════════

# ─── 資料庫（必填）───────────────────────────────────────────────────────────
# 推薦 Neon（免費方案）：https://neon.tech
# 或 Supabase：Project Settings → Database → Connection string（URI 格式）
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"


# ─── AI 模型（建議 3 個全填，競技場需要）────────────────────────────────────

# Anthropic Claude【必填】
# 申請：https://console.anthropic.com → API Keys
# 費率：claude-opus-4-6 $15/1M tokens；日常用量約 $1~5 USD/月
ANTHROPIC_API_KEY="sk-ant-api03-..."

# OpenAI GPT-4o【選填 — AI 競技場對比用】
# 申請：https://platform.openai.com/api-keys
# 費率：gpt-4o-mini $0.15/1M tokens（非常便宜）
OPENAI_API_KEY="sk-proj-..."

# Google Gemini【選填 — AI 競技場對比用】
# 申請：https://aistudio.google.com/app/apikey（有免費額度）
GEMINI_API_KEY="AIzaSy..."


# ─── FinMind 台股資料（強烈建議填入）────────────────────────────────────────
# 用途：法人籌碼、融資融券、期貨未平倉、財報、股價歷史
# 無 token → 每日 600 次（頁面重載幾次就超限）
# 有 token → 每日 6000 次（免費個人帳號，綽綽有餘）
# 申請：https://finmindtrade.com → 右上角 Login/Register → 登入後查 API Token
FINMIND_API_TOKEN=""


# ─── Google Sheets 整合（選填）──────────────────────────────────────────────
# 步驟：
#   1. GCP Console → IAM → 服務帳號 → 建立並下載 JSON 金鑰
#   2. 執行：base64 -i service-account.json | tr -d '\n'  → 貼入下方
#   3. 把試算表共用給服務帳號的 Email（至少編輯者權限）
GOOGLE_SERVICE_ACCOUNT_BASE64=""


# ─── Discord 整合（選填）─────────────────────────────────────────────────────
# Webhook（每日報告推播）：Discord 伺服器 → 編輯頻道 → 整合 → Webhooks → 新增
DISCORD_WEBHOOK_URL="https://discord.com/api/webhooks/..."

# Bot Token（雙向互動，目前為選用）：
# https://discord.com/developers/applications → New Application → Bot → Reset Token
DISCORD_BOT_TOKEN=""


# ─── Cron Job 安全性（部署 Vercel 時必填）────────────────────────────────────
# 保護 /api/cron/* 與 /api/ai-trading/update-performance 路由
# 產生方式：openssl rand -hex 32
# Vercel 中也需設定同一組值：Settings → Environment Variables
CRON_SECRET="your-random-secret-here"
