// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Trade {
  id         Int      @id @default(autoincrement())
  symbol     String   // e.g., 'AAPL', '2330.TW'
  type       String   // 'BUY' or 'SELL'
  shares     Float    // Quantity bought/sold
  price      Float    // Price per share
  currency   String   @default("TWD") // E.g., 'TWD', 'USD'
  date       DateTime @default(now()) // Custom Trade Date
  categoryId String?  
  category   PortfolioCategory? @relation(fields: [categoryId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model PortfolioCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  trades    Trade[]
}

model DataSource {
  id        String   @id @default(cuid())
  name      String
  url       String
  type      String   // 'RSS' or 'HTML'
  createdAt DateTime @default(now())
}

model NetWorthSnapshot {
  id         Int      @id @default(autoincrement())
  date       DateTime @default(now()) @unique
  totalValue Float    // Total aggregated value in the base currency (TWD)
  currency   String   @default("TWD") // Base currency of the snapshot
  createdAt  DateTime @default(now())
}
