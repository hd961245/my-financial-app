// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Trade {
  id         Int      @id @default(autoincrement())
  symbol     String   // e.g., 'AAPL', '2330.TW'
  type       String   // 'BUY' or 'SELL'
  shares     Float    // Quantity bought/sold
  price      Float    // Price per share
  currency   String   @default("TWD") // E.g., 'TWD', 'USD'
  date       DateTime @default(now()) // Custom Trade Date
  categoryId String?
  category   PortfolioCategory? @relation(fields: [categoryId], references: [id])
  accountId  String?  // Optional for backward compatibility but required for paper trading
  account    Account? @relation(fields: [accountId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([symbol])
  @@index([date])
  @@index([categoryId])
}

model PortfolioCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  trades    Trade[]
}

model DataSource {
  id        String   @id @default(cuid())
  name      String
  url       String   @unique
  type      String   // 'RSS' or 'HTML'
  createdAt DateTime @default(now())
}

model NetWorthSnapshot {
  id         Int      @id @default(autoincrement())
  date       DateTime @default(now()) @unique
  totalValue Float    // Total aggregated value in the base currency (TWD)
  currency   String   @default("TWD") // Base currency of the snapshot
  createdAt  DateTime @default(now())
}

model Account {
  id           String   @id @default(cuid())
  name         String   @default("Default Account")
  currency     String   @default("TWD")
  accountType  String   @default("PAPER") // 'PAPER' (simulated) | 'REAL' (record-only)
  balance      Float    @default(0) // Current available cash
  totalDeposit Float    @default(0) // Total historically deposited
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  trades       Trade[]
  transactions AccountTransaction[]
}

model AccountTransaction {
  id         Int      @id @default(autoincrement())
  accountId  String
  account    Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  type       String   // 'DEPOSIT', 'WITHDRAWAL', 'TRADE_BUY', 'TRADE_SELL'
  amount     Float    // Positive for deposit/sell, negative for withdrawal/buy
  notes      String?
  createdAt  DateTime @default(now())

  @@index([accountId])
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model DailyRecommendation {
  id        Int      @id @default(autoincrement())
  date      DateTime @default(now())
  symbol    String
  name      String
  action    String   // 'STRONG_BUY', 'BUY', 'HOLD', 'REDUCE', 'SELL', 'WATCH', 'AVOID'
  reason    String
  price     Float
  trend     String
  rsi       Float?
  isHolding Boolean  @default(false) // true = currently held, false = watchlist
  createdAt DateTime @default(now())

  @@index([date])
  @@index([symbol])
}

model DailyReport {
  id        Int      @id @default(autoincrement())
  date      DateTime @unique
  summary   String   // Opening paragraph (30-char market overview)
  fullReport String  // Full Markdown narrative from AI
  spotlight  String  // JSON array of top 1-3 spotlight stocks
  createdAt DateTime @default(now())

  @@index([date])
}

model PriceAlert {
  id          Int       @id @default(autoincrement())
  symbol      String
  name        String
  targetPrice Float
  condition   String    // 'ABOVE' | 'BELOW'
  isActive    Boolean   @default(true)
  triggeredAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([symbol])
  @@index([isActive])
}

model AITradingRec {
  id          Int       @id @default(autoincrement())
  date        DateTime  // recommendation date (midnight UTC)
  aiModel     String    // 'claude' | 'openai' | 'gemini'
  symbol      String
  name        String    @default("")
  action      String    // 'BUY' | 'SELL' | 'HOLD'
  confidence  Int       @default(50)  // 0-100
  targetPrice Float?
  stopLoss    Float?
  entryPrice  Float     // price at recommendation time
  reason      String
  factors     String?   // JSON: {technical, fundamental, sentiment, risk} 0-100
  exitPrice   Float?    // filled on close
  returnPct   Float?    // (exitPrice - entryPrice) / entryPrice * 100
  isWin       Boolean?  // true if returnPct > 0
  closedAt    DateTime?
  createdAt   DateTime  @default(now())

  @@unique([date, aiModel, symbol])
  @@index([date])
  @@index([aiModel])
}

